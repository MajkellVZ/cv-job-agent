# ---- Local model (Ollama) ----
# Install Ollama from https://ollama.com, then: `ollama pull llama3.1`
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ---- Aggregator: Indeed + hundreds of boards (recommended) ----
# Free key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---- Geography ----
# Comma-separated countries to search (ISO codes or names). Leave empty to
# search worldwide across all supported countries.
#   JOB_COUNTRIES=us,gb,de
JOB_COUNTRIES=

# ---- Specific company career pages ----
# Comma-separated. Each entry is either provider:token or a careers URL.
# The ATS (Greenhouse/Lever/Ashby/SmartRecruiters/Recruitee/Workable/Workday)
# is auto-detected for plain URLs.
#   COMPANY_CAREERS=greenhouse:stripe,lever:netflix,https://www.acme.com/careers
COMPANY_CAREERS=

# Optional: render JS-heavy career pages before scraping (needs Playwright).
# CAREERS_RENDER=1

# ---- Back-compat (still supported) ----
GREENHOUSE_BOARDS=
LEVER_BOARDS=
